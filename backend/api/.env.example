# Copie ce fichier en `.env` sur CHAQUE machine et adapte les valeurs locales.
# Le `.env` n'est PAS versionné : chaque PC garde son propre mot de passe Postgres.

# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=ccm4Gj4ZNHDb3V6hKZ2faguDq3fjOO_P
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Base de données PostgreSQL (DB_PASSWORD = celui de TON Postgres local)
